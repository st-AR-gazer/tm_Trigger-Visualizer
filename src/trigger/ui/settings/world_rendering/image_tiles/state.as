                    MT_SUBTYPE_COLORS_FX,
                    MT_SUBTYPE_COLOR_GRADING,
                    MT_SUBTYPE_DEPTH_OF_FIELD,
                    MT_SUBTYPE_DIRTY_LENS,
                    MT_SUBTYPE_FADING_TRANSITION,
                    MT_SUBTYPE_FOG,
                    MT_SUBTYPE_GHOST,
                    MT_SUBTYPE_HDR_BLOOM,
                    MT_SUBTYPE_IMAGE,
                    MT_SUBTYPE_MANIALINK_UI,
                    MT_SUBTYPE_MANIALINK_URL,
                    MT_SUBTYPE_MUSIC_VOLUME,
                    MT_SUBTYPE_SOUND_FX,
                    MT_SUBTYPE_SPECTATORS,
                    MT_SUBTYPE_TEXT,
                    MT_SUBTYPE_TIME,
                    MT_SUBTYPE_TIME_SPEED,
                    MT_SUBTYPE_RESET
                };
                for (uint i = 0; i < keys.Length; i++) {
                    SetTileIconEnabledForSubtype(keys[i], true);
                    SetTileIconCustomStoragePathForSubtype(keys[i], "");
                }
                G_TileIconPathInputs.DeleteAll();
                G_ActiveTileIconExplorerKey = "";
            }
