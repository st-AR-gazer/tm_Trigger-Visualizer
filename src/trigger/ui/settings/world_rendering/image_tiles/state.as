                if (key == MT_SUBTYPE_PLAYER_CAMERA_SUBTYPE_CAM_DEFAULT) return S_ShowTileIconMediaTrackerCamDefault;
                if (key == MT_SUBTYPE_PLAYER_CAMERA_SUBTYPE_CAM_1) return S_ShowTileIconMediaTrackerCam1;
