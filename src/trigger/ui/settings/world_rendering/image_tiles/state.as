                    MT_SUBTYPE_FADING_TRANSITION,
                    MT_SUBTYPE_FOG,
                    MT_SUBTYPE_GHOST,
                    MT_SUBTYPE_HDR_BLOOM,
                    MT_SUBTYPE_IMAGE,
